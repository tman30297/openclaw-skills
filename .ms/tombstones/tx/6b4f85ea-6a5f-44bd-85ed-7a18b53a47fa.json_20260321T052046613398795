  "payload_json": "{\"format_version\":\"1.0\",\"metadata\":{\"id\":\"after-uses-fallback-chain\",\"name\":\"cron-model-errors\",\"version\":\"0.1.0\",\"description\":\"Fix cron jobs failing with \\\"model not found\\\" errors\",\"tags\":[\"cron\",\"openclaw\",\"ollama\",\"fix\"],\"requires\":[],\"provides\":[],\"platforms\":[],\"author\":null,\"license\":null},\"sections\":[{\"id\":\"problem\",\"title\":\"Problem\",\"blocks\":[{\"id\":\"problem-block-1\",\"block_type\":\"text\",\"content\":\"Cron jobs fail with errors like:\\n- `ollama/gemma3:4b: model not found`\\n- `ollama/qwen3:8b: model not found`\\n- `ollama/llama3.2:3b: model not found`\"}]},{\"id\":\"root-cause\",\"title\":\"Root Cause\",\"blocks\":[{\"id\":\"root-cause-block-1\",\"block_type\":\"text\",\"content\":\"Cron jobs hardcode specific model names instead of using the default fallback chain. When the model isn't downloaded, the job fails.\"}]},{\"id\":\"solution\",\"title\":\"Solution\",\"blocks\":[{\"id\":\"solution-block-1\",\"block_type\":\"text\",\"content\":\"Change the model in the cron job to use `default` instead of a specific model. This allows the system to use the fallback chain.\"},{\"id\":\"solution-block-2\",\"block_type\":\"text\",\"content\":\"### Example\"}]},{\"id\":\"verify-models\",\"title\":\"Verify Models\",\"blocks\":[{\"id\":\"verify-models-block-1\",\"block_type\":\"code\",\"content\":\"```bash\\n\\n```bash\"},{\"id\":\"verify-models-block-2\",\"block_type\":\"text\",\"content\":\"ollama list\"},{\"id\":\"verify-models-block-3\",\"block_type\":\"code\",\"content\":\"```\\n\\nIf models are missing, pull them:\\n```bash\"},{\"id\":\"verify-models-block-4\",\"block_type\":\"text\",\"content\":\"ollama pull gemma3:4b\\nollama pull llama3.2:3b\\nollama pull qwen3:8b\"}]},{\"id\":\"jobs-that-had-this-issue\",\"title\":\"Jobs That Had This Issue\",\"blocks\":[]},{\"id\":\"prevention\",\"title\":\"Prevention\",\"blocks\":[]},{\"id\":\"related\",\"title\":\"Related\",\"blocks\":[{\"id\":\"related-block-1\",\"block_type\":\"code\",\"content\":\"```\\n\\n\\n- Self-improvement session\\n- PDF Summarizer\\n- Research Aggregator\\n- brain-graph-updater\\n\\n\\nAlways use `model: \\\"default\\\"` in cron job configurations. This ensures fallback to working models if primary isn't available.\\n\\n\\n- OpenClaw cron jobs: `openclaw cron list`\\n- Check errors: `openclaw cron list | grep error`\"}]}]}",
